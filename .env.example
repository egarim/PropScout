# PostgreSQL (uses existing Docker container)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=propscout
POSTGRES_USER=propscout
POSTGRES_PASSWORD=changeme

# Directus
DIRECTUS_SECRET=changeme-long-random-string
DIRECTUS_ADMIN_EMAIL=admin@propscout.local
DIRECTUS_ADMIN_PASSWORD=changeme

# MinIO
MINIO_ROOT_USER=propscout
MINIO_ROOT_PASSWORD=changeme
MINIO_BUCKET_IMAGES=propscout-images
MINIO_BUCKET_RAW=propscout-raw

# Apify
APIFY_API_TOKEN=your-apify-token-here

# OpenRouter (AI Agent)
OPENROUTER_API_KEY=your-openrouter-key-here

# Agent API
AGENT_API_PORT=3100
AGENT_API_SECRET=changeme

# React UI
UI_PORT=3200
VITE_API_URL=http://localhost:3100
